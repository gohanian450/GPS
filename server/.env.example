# ---- Configuration du backend RouteTrack ----

# Clé API TomTom (routing + tuiles de trafic).
# Obtenez-en une gratuitement sur https://developer.tomtom.com/
# IMPORTANT : cette clé n'est utilisée que côté serveur et n'est JAMAIS
# exposée au navigateur.
TOMTOM_API_KEY=votre_cle_tomtom_ici

# Port d'écoute de l'API (optionnel, 3001 par défaut).
PORT=3001
