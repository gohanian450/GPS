# ---- Configuration RouteTrack ----
# En local : copiez ce fichier vers .env
# Sur Vercel : définissez ces variables dans Project Settings → Environment Variables

# --- Base de données Turso (libSQL) ---
# Créez une base sur https://turso.tech puis récupérez l'URL et le token :
#   turso db create routetrack
#   turso db show routetrack --url
#   turso db tokens create routetrack
TURSO_DATABASE_URL=libsql://votre-base-xxxx.turso.io
TURSO_AUTH_TOKEN=votre_token_turso

# En local, vous pouvez laisser les variables Turso vides : l'application
# retombe alors sur un fichier SQLite local (file:routetrack.db).

# --- TomTom (routing + tuiles de trafic) ---
# Clé gratuite sur https://developer.tomtom.com/
# Utilisée UNIQUEMENT côté serveur, jamais exposée au navigateur.
TOMTOM_API_KEY=votre_cle_tomtom_ici

# Port du serveur de dev local (optionnel, 3001 par défaut). Ignoré sur Vercel.
PORT=3001
